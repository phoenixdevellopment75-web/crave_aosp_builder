#!/usr/bin/env bash

set -euo pipefail

export ROM_NAME="PixelOS"
export ROM_BRANCH="fifteen"
export DEVICE_CODENAME="crosshatch"
export DEVICE_NAME="Pixel 3 XL"

export BUILD_TARGET="lineage_crosshatch-userdebug"
export BUILD_COMMAND="mka bacon"
export REPO_SYNC_JOBS="${REPO_SYNC_JOBS:-4}"
export BUILD_JOBS="${BUILD_JOBS:-4}"
export CCACHE_MAXSIZE="${CCACHE_MAXSIZE:-8G}"
export REPO_DEPTH="${REPO_DEPTH:-1}"

export SOURCE_ROOT="${GITHUB_WORKSPACE:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}/source"
export ARTIFACTS_DIR="${GITHUB_WORKSPACE:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}/artifacts"
export LOGS_DIR="${GITHUB_WORKSPACE:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}/logs"
export CCACHE_DIR="${GITHUB_WORKSPACE:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}/ccache"

export MANIFEST_URL="https://github.com/PixelOS-AOSP/manifest.git"
export MANIFEST_BRANCH="fifteen"

export LINEAGE_BRANCH="lineage-22.2"
export THE_MUPPETS_BRANCH="lineage-22.2"
